# ==============================================
# ASPCare Backend - Environment Variables Template
# ==============================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control!

# ---- Database ----
DB_URL=jdbc:postgresql://localhost:5432/itemlist
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# ---- Mail (Gmail SMTP) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM=your_email@gmail.com

# ---- Support Chat Mail (separate app password) ----
SUPPORT_MAIL_PASSWORD=your_support_app_password_here

# ---- JWT ----
JWT_SECRET=your_jwt_secret_min_32_chars_here

# ---- Carwasher JWT (separate token config) ----
CARWASHER_JWT_SECRET=your_carwasher_jwt_secret_here
CARWASHER_JWT_EXPIRATION_MS=86400000

# ---- PhonePe Payment Gateway ----
PHONEPE_MERCHANT_ID=your_merchant_id
PHONEPE_SALT_KEY=your_salt_key
PHONEPE_SALT_INDEX=1
PHONEPE_CLIENT_ID=your_client_id
PHONEPE_CLIENT_SECRET=your_client_secret

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your_google_client_id

# ---- Facebook OAuth ----
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
